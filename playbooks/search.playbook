evaluate "Array.from(document.querySelectorAll('#web .algo')).map(function(card){var a=card.querySelector('.compTitle a');if(a===null)return null;var titleEl=a.querySelector('h3 span')||a.querySelector('h3')||a;var descEl=card.querySelector('.compText p, .compText span');var desc=descEl?descEl.textContent.trim().slice(0,200):'';var titleText=titleEl.textContent.trim();var href=a.href||'';if(titleText==='')return null;return '## '+titleText+'\n'+href+'\n'+desc}).filter(Boolean).join('\n\n')"