{
  "scope": "agent",
  "name": "copilot-skill-web",
  "version": "0.1.1-local",
  "license": "Apache-2.0",
  "description": "Copilot skill for searching the web and fetching content from URLs",
  "dependencies": [
    "aux4/copilot",
    "aux4/browser",
    "aux4/ai-agent"
  ],
  "profiles": [
    {
      "name": "copilot:skills",
      "commands": [
        {
          "name": "web",
          "execute": [
            "profile:copilot:skills:web"
          ],
          "help": {
            "text": "Search the web and fetch content from URLs using a headless browser"
          }
        }
      ]
    },
    {
      "name": "copilot:skills:web",
      "commands": [
        {
          "name": "prompt",
          "execute": [
            "cat ${packageDir}/instructions/web.md"
          ],
          "help": {
            "text": "Get the prompt/instructions for this skill"
          }
        },
        {
          "name": "model",
          "execute": [
            "echo fast"
          ],
          "help": {
            "text": "Get the preferred model intent for this skill"
          }
        },
        {
          "name": "search",
          "execute": [
            "set:script=!cat ${packageDir}/lib/extract-search-results.js",
            "aux4 browser start --persistent true >/dev/null 2>&1 & sleep 3; SESSION=$(aux4 browser open --url \"https://search.yahoo.com/search?p=$(echo '${query}' | sed 's/ /+/g')\"); aux4 browser eval --session $SESSION --script value(script); aux4 browser close --session $SESSION >/dev/null 2>&1; aux4 browser stop >/dev/null 2>&1"
          ],
          "help": {
            "text": "Search the web for information on a topic",
            "variables": [
              {
                "name": "query",
                "text": "The search query",
                "arg": true
              }
            ]
          }
        },
        {
          "name": "fetch",
          "execute": [
            "set:script=!cat ${packageDir}/lib/extract-content.js",
            "aux4 browser start --persistent true >/dev/null 2>&1 & sleep 3; SESSION=$(aux4 browser open --url \"${url}\"); sleep 3; aux4 browser eval --session $SESSION --script value(script); aux4 browser close --session $SESSION >/dev/null 2>&1; aux4 browser stop >/dev/null 2>&1"
          ],
          "help": {
            "text": "Fetch and extract the main content from a URL",
            "variables": [
              {
                "name": "url",
                "text": "The URL to fetch",
                "arg": true
              }
            ]
          }
        },
        {
          "name": "fields",
          "execute": [
            "set:script=!cat ${packageDir}/lib/extract-fields.js",
            "aux4 browser eval --session ${session} --script value(script)"
          ],
          "help": {
            "text": "Extract form fields from the current browser session",
            "variables": [
              {
                "name": "session",
                "text": "The browser session ID",
                "arg": true
              }
            ]
          }
        },
        {
          "name": "interact",
          "execute": [
            "aux4 browser execute --session ${session} --instructions ${instructions}"
          ],
          "help": {
            "text": "Execute playbook instructions on the current browser session",
            "variables": [
              {
                "name": "session",
                "text": "The browser session ID"
              },
              {
                "name": "instructions",
                "text": "Path to the playbook instructions file"
              }
            ]
          }
        },
        {
          "name": "open",
          "execute": [
            "aux4 browser start --persistent true >/dev/null 2>&1 & sleep 3; aux4 browser open --url \"${url}\""
          ],
          "help": {
            "text": "Open a URL in the browser and return the session ID",
            "variables": [
              {
                "name": "url",
                "text": "The URL to open",
                "arg": true
              }
            ]
          }
        },
        {
          "name": "download",
          "execute": [
            "aux4 browser start --persistent true >/dev/null 2>&1 & sleep 3; SESSION=$(aux4 browser open); aux4 browser download --session $SESSION --url \"${url}\" --output \"${output}\"; aux4 browser close --session $SESSION >/dev/null 2>&1; aux4 browser stop >/dev/null 2>&1"
          ],
          "help": {
            "text": "Download a file from a URL",
            "variables": [
              {
                "name": "url",
                "text": "The URL to download",
                "arg": true
              },
              {
                "name": "output",
                "text": "Output file path",
                "default": "download"
              }
            ]
          }
        },
        {
          "name": "save-pdf",
          "execute": [
            "aux4 browser save-pdf --session ${session} --output \"${output}\" --format \"${format}\" --printBackground \"${printBackground}\""
          ],
          "help": {
            "text": "Save the current page as a PDF (requires an open session)",
            "variables": [
              {
                "name": "session",
                "text": "The browser session ID",
                "arg": true
              },
              {
                "name": "output",
                "text": "Output file path",
                "default": "page.pdf"
              },
              {
                "name": "format",
                "text": "Paper format: Letter, A4, Legal, Tabloid",
                "default": ""
              },
              {
                "name": "printBackground",
                "text": "Include background graphics",
                "default": "false"
              }
            ]
          }
        },
        {
          "name": "close",
          "execute": [
            "aux4 browser close --session ${session} >/dev/null 2>&1; aux4 browser stop >/dev/null 2>&1"
          ],
          "help": {
            "text": "Close a browser session and stop the browser",
            "variables": [
              {
                "name": "session",
                "text": "The browser session ID",
                "arg": true
              }
            ]
          }
        },
        {
          "name": "recipe",
          "execute": [
            "profile:copilot:skills:web:recipe"
          ],
          "help": {
            "text": "Manage reusable web task recipes"
          }
        }
      ]
    },
    {
      "name": "copilot:skills:web:recipe",
      "commands": [
        {
          "name": "list",
          "execute": [
            "ls ${recipeDir}/*.recipe 2>/dev/null | while read f; do basename \"$f\" .recipe; done || echo \"No recipes found\""
          ],
          "help": {
            "text": "List available recipes",
            "variables": [
              {
                "name": "recipeDir",
                "text": "Directory where recipes are stored",
                "default": ".recipes"
              }
            ]
          }
        },
        {
          "name": "create",
          "execute": [
            "aux4 ai agent ask --instructions ${packageDir}/instructions/recipe.md --question 'Create a recipe named \"${name}\" for: ${task}. ${message}'"
          ],
          "help": {
            "text": "Create a new recipe by performing a task and saving the steps",
            "variables": [
              {
                "name": "name",
                "text": "Name for the recipe"
              },
              {
                "name": "task",
                "text": "Description of the task to automate",
                "arg": true
              },
              {
                "name": "message",
                "text": "Additional context or instructions",
                "default": ""
              },
              {
                "name": "recipeDir",
                "text": "Directory where recipes are stored",
                "default": ".recipes"
              }
            ]
          }
        },
        {
          "name": "run",
          "execute": [
            "set:url=!head -1 ${recipeDir}/${name}.recipe | sed 's/^url: //' | sed \"s/{[^}]*}/${input}/g\"",
            "set:tmpPlaybook=!mktemp /tmp/recipe-XXXXX.playbook",
            "tail -n +3 ${recipeDir}/${name}.recipe | sed \"s/{[^}]*}/${input}/g\" > ${tmpPlaybook}",
            "aux4 browser start --persistent true >/dev/null 2>&1 & sleep 3; SESSION=$(aux4 browser open --url \"${url}\"); sleep 2; aux4 browser execute --session $SESSION --instructions ${tmpPlaybook}; aux4 browser close --session $SESSION >/dev/null 2>&1; aux4 browser stop >/dev/null 2>&1; rm -f ${tmpPlaybook}"
          ],
          "help": {
            "text": "Run a saved recipe with input values",
            "variables": [
              {
                "name": "name",
                "text": "Name of the recipe to run",
                "arg": true
              },
              {
                "name": "input",
                "text": "Input value to substitute into recipe variables"
              },
              {
                "name": "recipeDir",
                "text": "Directory where recipes are stored",
                "default": ".recipes"
              }
            ]
          }
        }
      ]
    }
  ]
}
